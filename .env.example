# Copier ce fichier en .env et renseigner les valeurs réelles

# Azure AI Foundry
# Clé API : Azure AI Foundry > votre projet > Settings > Keys and Endpoint
AZURE_API_KEY=your_azure_api_key_here

# Endpoint OpenAI v1 du projet Foundry
# Format : https://<resource>.services.ai.azure.com/api/projects/<project>/openai/v1
AZURE_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>/openai/v1

# Serper (recherche web)
# Obtenir une clé sur https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# Tracing CrewAI (optionnel)
CREWAI_TRACING_ENABLED=false
